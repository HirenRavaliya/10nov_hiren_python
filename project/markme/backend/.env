# Hajri Hub Backend Environment Variables
# Copy this to .env and fill in values before production deployment

# Django
SECRET_KEY=django-insecure-hajri-hub-dev-key-change-in-production-2026
DEBUG=True

# Face Recognition
FACE_RECOGNITION_TOLERANCE=0.5

# Firebase (optional – for push notifications to the mobile app)
# Download your service account JSON from Firebase Console > Project Settings > Service Accounts
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
